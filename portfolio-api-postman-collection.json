						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sarang\",\n    \"imageUrl\": \"/api/profile/image/1\",\n    \"bannerUrl\": \"https://images.unsplash.com/photo-1506744038136-46273834b3fb\"\n}"
