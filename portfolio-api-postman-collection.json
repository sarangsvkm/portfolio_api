			"name": "API User (Auth)",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
					}
				}
			]
		},
		{
			"name": "Profile & Assets",
			"item": [
				{
					"name": "Get All Profiles",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/profile"
					}
				},
				{
					"name": "Update Profile Assets (URLs)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password\",\n    \"profile\": {\n        \"name\": \"Sarang\",\n        \"imageUrl\": \"/api/profile/image/1\",\n        \"bannerUrl\": \"https://images.unsplash.com/photo-1506744038136-46273834b3fb\",\n        \"resumeUrl\": \"/api/upload/view/resume.pdf\"\n    }\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/profile/1", "host": ["{{baseUrl}}"], "path": ["api", "profile", "1"] }
					}
				},
				{
					"name": "Upload Image to DB (Binary)",
					"request": {
						"method": "POST",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "username", "value": "admin", "type": "text" },
								{ "key": "password", "value": "password", "type": "text" },
								{ "key": "file", "type": "file", "src": [] }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/profile/image/1", "host": ["{{baseUrl}}"], "path": ["api", "profile", "image", "1"] }
					}
				},
				{
					"name": "View Image from DB",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/profile/image/1"
					}
				},
				{
					"name": "Upload to Local Disk (Fastest)",
					"request": {
						"method": "POST",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "file", "type": "file", "src": [] }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/upload", "host": ["{{baseUrl}}"], "path": ["api", "upload"] }
					}
				}
			]
		},
		{
			"name": "Resume (Full)",
			"item": [
				{
					"name": "Get Full Resume",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/resume"
