					"request": {
						"method": "POST",
						"header": [
							{ "key": "X-Admin-Username", "value": "admin" },
							{ "key": "X-Admin-Password", "value": "password" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "file", "type": "file", "src": [] }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/profile/image/1", "host": ["{{baseUrl}}"], "path": ["api", "profile", "image", "1"] }
					}
				}
